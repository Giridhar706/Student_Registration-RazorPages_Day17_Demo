@page
@model StudentRegistrationPortal.Pages.RegisterModel

@{
    ViewData["Title"] = "Student Registration";
}

<h2>Student Registration Portal</h2>

<form method="post">

    <div>
        <label>Enter Student Name:</label>
        <input type="text" asp-for="StudentName" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Register
    </button>

</form>

<br />

@if (!string.IsNullOrEmpty(Model.Message))
{
    <h3>@Model.Message</h3>
}